{
  "name": "smichaelsen/melon-images",
  "type": "typo3-cms-extension",
  "description": "Responsive Image Management",
  "license": "GPL-3.0",
  "autoload": {
    "psr-4": {
      "Smichaelsen\\MelonImages\\": "Classes/"
    }
  },
  "require": {
    "php": ">=7.4.0",
    "typo3/cms-core": "^12.0 || ^13.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^2.1",
    "typo3/cms-extbase": "^12.0 || ^13.0",
    "typo3/cms-lowlevel": "^12.0 || ^13.0"
  },
  "scripts": {
    "phpstan": "phpstan analyse"
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "melon_images"
    }
  }
}
